function filterMonth(month, btn) {
  document.querySelectorAll('.phase-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.month-block').forEach(block => {
    if (month === 'all' || block.dataset.month === month) {
